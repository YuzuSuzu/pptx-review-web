# =====================================================================
# AI プロバイダー設定
# 使いたい AI に合わせて AI_PROVIDER を設定し、対応する API キーを入力してください。
# =====================================================================

# 使用する AI プロバイダー（省略可）
#   anthropic  → Claude (Anthropic API) ※デフォルト
#   openai     → GPT-4o (OpenAI API / Codex CLI 互換)
#
# ★ AI_PROVIDER は省略しても自動検出されます ★
#   - OPENAI_API_KEY のみ設定されている場合    → openai を自動選択
#   - ANTHROPIC_API_KEY が設定されている場合   → anthropic を自動選択
#   - 両方設定されている場合                  → anthropic を優先
#
# 明示的に切り替えたい場合のみ設定してください:
# AI_PROVIDER=openai

# =====================================================================
# Anthropic (Claude) を使う場合
# https://console.anthropic.com/ で取得
# =====================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =====================================================================
# OpenAI を使う場合（Codex CLI 互換）
# https://platform.openai.com/api-keys で取得
# =====================================================================
OPENAI_API_KEY=your-openai-api-key-here

# 使用するOpenAIモデル（省略時は gpt-4o）
# Azure OpenAI の場合はデプロイメント名を指定（例: gpt-4o-deployment）
# 例: gpt-4o / gpt-4o-mini / gpt-4-turbo
# OPENAI_MODEL=gpt-4o

# =====================================================================
# OpenAI 接続先の切り替え（省略時は openai）
# =====================================================================
#   openai → 標準 OpenAI API（デフォルト）
#   azure  → Azure OpenAI Service
#
# OPENAI_API_TYPE=openai

# ---------------------------------------------------------------------
# LiteLLM Proxy など OpenAI 互換エンドポイントを使う場合
#   OPENAI_API_TYPE=openai のまま、OPENAI_BASE_URL にプロキシURLを指定する
#   （Codex CLI の config.toml の base_url に相当）
# ---------------------------------------------------------------------
# OPENAI_BASE_URL=https://xxxxx.net/

# =====================================================================
# Azure OpenAI を使う場合（OPENAI_API_TYPE=azure のとき必須）
# https://portal.azure.com/ でリソースを作成して取得
# =====================================================================
# OPENAI_API_TYPE=azure
# OPENAI_API_KEY は Azure OpenAI の API キーを設定（上記 OPENAI_API_KEY と共用）
#
# Azure OpenAI エンドポイント URL
# 例: https://<リソース名>.openai.azure.com/
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
#
# API バージョン（省略時は 2024-02-01）
# AZURE_OPENAI_API_VERSION=2024-02-01
#
# OPENAI_MODEL にはデプロイメント名を指定（Azure ポータルで確認）
# OPENAI_MODEL=gpt-4o-deployment

# =====================================================================
# スキルフォルダのパス（省略可・自動検出）
# =====================================================================
# 省略した場合、以下の順で自動検出します：
#   1. Codex CLI 標準パス  : C:\Users\<ユーザー名>\.codex\skills\pptx-review-text
#   2. Claude Code 標準パス: C:\Users\<ユーザー名>\.claude\skills\pptx-reviewer
#   3. 相対パス（開発用）  : ../skills/pptx-reviewer
#
# 自動検出がうまくいかない場合や別の場所に置いている場合のみ設定してください:
# SKILL_DIR=C:\Users\ユーザー名\.codex\skills\pptx-review-text

# =====================================================================
# サーバー設定（任意）
# =====================================================================
# ポート番号（デフォルト: 5000）
# イントラネット公開時は任意のポートに変更可能（例: 49156）
# PORT=5000

# デバッグモード（ローカル開発時のみ true にする。イントラネット公開時は false）
# FLASK_DEBUG=false

# waitress の同時処理スレッド数（デフォルト: 8）
# 同時接続ユーザ数が多い場合は増やす（例: 16）
# WAITRESS_THREADS=8
