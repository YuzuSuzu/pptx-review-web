# =====================================================================
# AI プロバイダー設定
# 使いたい AI に合わせて AI_PROVIDER を設定し、対応する API キーを入力してください。
# =====================================================================

# 使用する AI プロバイダー（省略可）
#   anthropic  → Claude (Anthropic API) ※デフォルト
#   openai     → GPT-4o (OpenAI API / Codex CLI 互換)
#
# ★ AI_PROVIDER は省略しても自動検出されます ★
#   - OPENAI_API_KEY のみ設定されている場合    → openai を自動選択
#   - ANTHROPIC_API_KEY が設定されている場合   → anthropic を自動選択
#   - 両方設定されている場合                  → anthropic を優先
#
# 明示的に切り替えたい場合のみ設定してください:
# AI_PROVIDER=openai

# =====================================================================
# Anthropic (Claude) を使う場合
# https://console.anthropic.com/ で取得
# =====================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =====================================================================
# OpenAI を使う場合（Codex CLI 互換）
# https://platform.openai.com/api-keys で取得
# =====================================================================
OPENAI_API_KEY=your-openai-api-key-here

# 使用するOpenAIモデル（省略時は gpt-4o）
# 例: gpt-4o / gpt-4o-mini / gpt-4-turbo
# OPENAI_MODEL=gpt-4o

# =====================================================================
# サーバー設定（任意）
# =====================================================================
# ポート番号（デフォルト: 5000）
# イントラネット公開時は任意のポートに変更可能（例: 49156）
# PORT=5000

# デバッグモード（ローカル開発時のみ true にする。イントラネット公開時は false）
# FLASK_DEBUG=false
